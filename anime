
local data = "<coroutine object Command.__call__ at 0x7abb639a80>"
local decoded = game:GetService("HttpService"):Base64Decode(data)

local function lzw_decompress(input)
    local dict = {}
    for i=0,255 do dict[i] = string.char(i) end

    local result = {}
    local codes = {}

    for num in string.gmatch(input, "%d+") do
        table.insert(codes, tonumber(num))
    end

    local w = string.char(codes[1])
    table.insert(result, w)

    local dict_size = 256

    for i=2,#codes do
        local k = codes[i]
        local entry

        if dict[k] then
            entry = dict[k]
        else
            entry = w .. string.sub(w,1,1)
        end

        table.insert(result, entry)
        dict[dict_size] = w .. string.sub(entry,1,1)
        dict_size = dict_size + 1
        w = entry
    end

    return table.concat(result)
end

local decompressed = lzw_decompress(decoded)
loadstring(decompressed)()